/*
 * Platform feature detection for thread.cc, generated by CMake. The only knobs
 * thread.cc needs are which pthread thread-naming API is available. likely.h is
 * self-contained and does NOT depend on this file (it detects __builtin_expect
 * directly), so HAVE___BUILTIN_EXPECT is not defined here.
 */

#pragma once

#cmakedefine HAVE_PTHREADS 1
#cmakedefine HAVE_PTHREAD_SETNAME_NP 1
#cmakedefine HAVE_PTHREAD_SET_NAME_NP 1
#cmakedefine HAVE_PTHREAD_NP_H 1
